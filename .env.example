# Merism dev environment variables.
# Copy to `.env` and fill in real values. `.env` is gitignored.

# ── Django ─────────────────────────────────────────────────
DJANGO_SETTINGS_MODULE=merism.settings.dev
SECRET_KEY=change-me-before-prod
DEBUG=1
ALLOWED_HOSTS=localhost,127.0.0.1

# ── Database ───────────────────────────────────────────────
DATABASE_URL=postgres://merism:merism@localhost:5542/merism
POSTGRES_HOST=localhost
POSTGRES_PORT=5542
POSTGRES_DB=merism
POSTGRES_USER=merism
POSTGRES_PASSWORD=merism

# ── Redis ──────────────────────────────────────────────────
REDIS_URL=redis://localhost:6479/0
CELERY_BROKER_URL=redis://localhost:6479/1
CELERY_RESULT_BACKEND=redis://localhost:6479/2
CHANNELS_REDIS_URL=redis://localhost:6479/3

# ── Object storage (S3 / MinIO) ────────────────────────────
OBJECT_STORAGE_ENDPOINT=http://localhost:9100
OBJECT_STORAGE_ACCESS_KEY=merism
OBJECT_STORAGE_SECRET_KEY=merism-dev-password
OBJECT_STORAGE_BUCKET=merism-dev
OBJECT_STORAGE_REGION=us-east-1

# ── LLM (DeepSeek via OpenAI-compatible endpoint) ──────────
# Leave MERISM_LLM_API_KEY empty to skip live-LLM tests.
MERISM_LLM_API_KEY=
MERISM_LLM_BASE_URL=https://api.deepseek.com
MERISM_LLM_MODEL=deepseek-chat
MERISM_LLM_REASONER_MODEL=deepseek-reasoner

# ── TTS / STT / Vision (Qwen via DashScope) ────────────────
DASHSCOPE_API_KEY=
DASHSCOPE_TTS_MODEL=cosyvoice-v2
DASHSCOPE_STT_MODEL=paraformer-realtime-v2
DASHSCOPE_VISION_MODEL=qwen-vl-max

# ── Channel credential encryption (Fernet) ─────────────────
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
MERISM_CHANNEL_ENCRYPTION_KEY=

# ── Feature flags (boolean env vars parsed with truthy check) ─
MERISM_KNOWLEDGE_VECTOR_SEARCH=1
MERISM_IM_RECRUITMENT=1
MERISM_IM_LIVE=0  # set to 1 only when you have real IM credentials configured

# ── Email (django-anymail, ADR 0001) ───────────────────────
# Provider one of: console (dev default) | resend | ses | mailgun | postmark
ANYMAIL_PROVIDER=console
DEFAULT_FROM_EMAIL=merism-dev@merism.test
# Only set the key for the provider you pick:
RESEND_API_KEY=
MAILGUN_API_KEY=
POSTMARK_SERVER_TOKEN=

# ── LLM observability (Langfuse, ADR 0001) ─────────────────
# Leave blank to disable. Get keys at https://cloud.langfuse.com or self-host.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# ── Sentry (application error tracking) ────────────────────
# Leave SENTRY_DSN empty to disable. Traces / profiling sample rates default
# to 0.0 — turn them up only when investigating a perf regression.
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_RELEASE=
SENTRY_TRACES_SAMPLE_RATE=0.0
SENTRY_PROFILES_SAMPLE_RATE=0.0
